{
  "name": "@cyanheads/nhtsa-vehicle-safety-mcp-server",
  "version": "0.2.3",
  "description": "Vehicle safety data from NHTSA — recalls, complaints, crash ratings, investigations, VIN decoding.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nhtsa-vehicle-safety-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "test": "vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "nhtsa",
    "vehicle-safety",
    "recalls",
    "vin-decoder",
    "crash-ratings",
    "ncap",
    "typescript"
  ],
  "author": "cyanheads",
  "homepage": "https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server/issues"
  },
  "mcpName": "io.github.cyanheads/nhtsa-vehicle-safety-mcp-server",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.2.12",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^25.5.2",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
