{
  "name": "@cyanheads/nhtsa-vehicle-safety-mcp-server",
  "version": "0.3.1",
  "description": "Vehicle safety data from NHTSA — recalls, complaints, crash ratings, investigations, VIN decoding.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nhtsa-vehicle-safety-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run build",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "tree": "bun run scripts/tree.ts",
    "format": "biome check --write --unsafe",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "test": "bunx vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio bun ./dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http bun ./dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "nhtsa",
    "vehicle-safety",
    "recalls",
    "vin-decoder",
    "crash-ratings",
    "ncap",
    "typescript"
  ],
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server#readme)",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "homepage": "https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/cyanheads/nhtsa-vehicle-safety-mcp-server/issues"
  },
  "mcpName": "io.github.cyanheads/nhtsa-vehicle-safety-mcp-server",
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.3.2",
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "brace-expansion": ">=2.0.3",
    "express-rate-limit": ">=8.2.2",
    "hono": ">=4.12.7",
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4",
    "yaml": ">=2.8.3"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.2.12",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^25.5.2",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
